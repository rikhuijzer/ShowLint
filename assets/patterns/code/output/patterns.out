~~~ 
<h3>p1.toml</h3>
<pre><code class="plaintext hljs">[p1]

match='name = ":[name]"' 

rewrite='''
# A new comment.
name = ":[name]"'''
</code></pre>
~~~

~~~ 
<h3>p2.toml</h3>
<pre><code class="plaintext hljs">[p2]

match='if :[var] === nothing' 

rewrite='if isnothing(:[var])'
</code></pre>
~~~

