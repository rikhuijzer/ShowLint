        - """
        - Obtains the number of matches from Comby's `-stats` output 
        - on stderr.
        - 
        - $(TYPEDSIGNATURES)
        - """
        - function number_of_matches(stderr::String)::Int
        8     regex = r"\"number_of_matches\": ([0-9]*)"
        8     m = match(regex, stderr)
        8     n_str = m[1]
        8     parse(Int, n_str)
        - end
