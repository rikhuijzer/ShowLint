        - function filter_patterns(repo::Repo, patterns::Vector{Pattern})
        4     predicates = repo.tags_predicates
       17     all_predicates_hold(tags) = all([P(tags) for P in predicates])
        4     filtered_patterns = filter(pat -> all_predicates_hold(pat.tags), patterns)
        - end
