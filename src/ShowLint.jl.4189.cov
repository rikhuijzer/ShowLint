        - """
        - Remove ANSI color codes from `text`.
        - 
        - $(TYPEDSIGNATURES) 
        - """
        - function ansi2html(text::String)::String
       16   escape_codes = Dict(
        -     "0;30" => "inherit",
        -     "0;31" => "red",
        -     "0;32" => "green",
        -     "0;34" => "blue",
        -     "0;1" => "inherit",
        -     "0;100;30" => "inherit",
        -     "0;41;30" => "red",
        -     "0;42;30" => "green",
        -     "0;43;30" => "orange",
        -     "0;2" => "gray"
        -   )
       16   for code in keys(escape_codes)
       80     before = "[" * code * "m"
       80     color = escape_codes[code]
       80     after = "<span style=\"color:$color;\">"
      160     text = replace(text, before => after)
        -   end
        8   no_color = "[0m"
        8   text = replace(text, no_color => "</span>")
        8   text = replace(text, r"WARNING: [^\n]*$" => "")
        8   text = replace(text, "/repo/" => "")
        8   text = replace(text, "" => "") 
        8   text = replace(text, "<!" => "&#60;!")
        8   text = replace(text, "[0;7;2m" => "")
        8   text = text[1:end-6]
        8   text = strip(text)
        8   return length(text) < 6 ? 
        -         "" :
        -         """
        -         ~~~ 
        -         <pre>
        -         <div class="hljs">$text</div>
        -         </pre>
        -         ~~~
        -         """
        - end
