        - """
        - Apply `pattern` to `repo`.
        - 
        - $(TYPEDSIGNATURES)
        - """
        - function apply(pat::Pattern, repo::Repo; 
        -     file_extensions="jl", in_place=false)
        - 
       88     start = Dates.now()
       44     configs_dir = "configs"
       44     configs_path = joinpath(project_root, "configs")
       44     repo_path = target_dir(repo)
        - 
       44     name = create_config(pat, configs_path)
       44     exclude_prefixes = join(repo.exclude_prefixes, ',')
        - 
        -     # Not pretty but it works.
       44     cmd = !in_place ? 
        -         `podman run
        -         --rm
        -         --volume $configs_path:/configs
        -         --volume $repo_path:/repo
        -         --entrypoint="sh"
        -         -it comby/comby
        -         -c "comby \
        -             -stats \
        -             -exclude-dir $exclude_prefixes \
        -             -config /configs/$name.toml \
        -             -directory /repo \
        -             -file-extensions $file_extensions \
        -             2>/repo/stderr.log
        -         "
        -         ` :
        -         `podman run
        -         --rm
        -         --volume $configs_path:/configs
        -         --volume $repo_path:/repo
        -         -it comby/comby
        -         -exclude-dir $exclude_prefixes
        -         -config /configs/$name.toml
        -         -directory /repo
        -         -file-extensions $file_extensions
        -         -in-place
        -         `
        - 
       44     stdout = IOBuffer()
       44     run(pipeline(cmd; stdout))
       44     out = String(take!(stdout))
       44     err = ""
       44     function avoid_franklin_parse_errors(out)
        8         out = replace(out, '`' => "&#96;")
        8         out = replace(out, '"' => "&#34;")
        8         out
        -     end
       44     if !in_place
        8         out = avoid_franklin_parse_errors(out)
        8         if !isnothing(out)
        8             out = ansi2html(out)
        -         end
        8         err = read(joinpath(repo_path, "stderr.log"), String) 
        -     end
       44     time = Dates.now() - start
       44     println("$(pat.id): $time")
       44     return (out, err)
        - end
