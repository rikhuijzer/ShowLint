        - """
        - Obtains the number of matches from Comby's `-stats` output 
        - on stderr.
        - 
        - $(TYPEDSIGNATURES)
        - """
        - function number_of_matches(stderr::String)::Int
     1052     regex = r"\"number_of_matches\": ([0-9]*)"
     1052     m = match(regex, stderr)
     1052     n_str = m[1]
     1052     parse(Int, n_str)
        - end
