        - const clones_dir = joinpath(homedir(), "clones") 
        - 
        - """
        - Directory of the host of `repo`. 
        - 
        - $(TYPEDSIGNATURES)
        - 
        - ### Example
        - ```
        - julia> host_dir("https://github.com") 
        - "github"
        - ```
        - """
        - function host_dir(repo::Repo)::String
     1533     host = repo.host
     3036     host_dir = startswith(host, "https://") ? host[9:end] : host
     1533     host_dir = lowercase(host_dir) == "github.com" ? "github" : host_dir
        - end
        - 
        - function target_dir(repo::Repo)
     1232     name = repo.name
     1232     joinpath(clones_dir, host_dir(repo), name) 
        - end
        - 
        - function page_path(repo::Repo)
      150     name = repo.name
      150     lowercase(joinpath(host_dir(repo), "$name.md"))
        - end
        - 
        - function clone_repositories()
        1     if !isdir(clones_dir)
        0         mkdir(clones_dir)
        -     end
        1     for repo in repositories()
      150         println("Cloning $(repo.name)")
      150         name = repo.name
      150         host = repo.host
      150         dest = target_dir(repo)
      150         if isdir(dest)
        0             cd(dest)
        0             run(`git pull --ff-only`)
        -         else
      150             run(`git clone
        -                 --depth=1
        -                 --no-tags
        -                 --single-branch
        -                 $host/$name $dest`)
        -         end
      150         println()
        -     end
        - end
