        - """
        - Create a Comby configuration file for `pat` at `dir`.
        - 
        - $(TYPEDSIGNATURES)
        - """
        - function create_config(pat::Pattern, dir::String)::String
     1082     id = pat.id
     1082     toml = pat.toml
     1082     name = "p$id"
     1082     text = """
        -         [$name] 
        - 
        -         $toml
        -         """
     1082     if isdir(dir)
    11746         foreach(name -> rm(name; recursive=true, force=true), readdir(dir))
        -     else
        1         mkdir(dir)
        -     end
     1082     file = joinpath(dir, "$name.toml")
     1082     open(file, "w") do io
        -         write(io, text)
        -     end
     1082     name
        - end
