        - """
        - Apply `pattern` to `repo`.
        - 
        - $(TYPEDSIGNATURES)
        - """
        - function apply(pat::Pattern, repo::Repo; 
        -     file_extensions="jl", in_place=false)
        - 
     2164     configs_dir = "configs"
     1082     configs_path = joinpath(project_root, "configs")
     1082     repo_path = target_dir(repo)
        - 
     1082     name = create_config(pat, configs_path)
     1082     exclude_prefixes = join(repo.exclude_prefixes, ',')
        - 
        -     # Not pretty but it works.
     1082     cmd = !in_place ? 
        -         `podman run
        -         --rm
        -         --volume $configs_path:/configs
        -         --volume $repo_path:/repo
        -         --entrypoint="sh"
        -         -it comby/comby
        -         -c "comby \
        -             -stats \
        -             -exclude-dir $exclude_prefixes \
        -             -config /configs/$name.toml \
        -             -directory /repo \
        -             -file-extensions $file_extensions \
        -             2>/repo/stderr.log
        -         "
        -         ` :
        -         `podman run
        -         --rm
        -         --volume $configs_path:/configs
        -         --volume $repo_path:/repo
        -         -it comby/comby
        -         -exclude-dir $exclude_prefixes
        -         -config /configs/$name.toml
        -         -directory /repo
        -         -file-extensions $file_extensions
        -         -in-place
        -         `
        - 
     1082     stdout = IOBuffer()
     1082     run(pipeline(cmd; stdout))
     1082     out = String(take!(stdout))
     1082     err = ""
     1082     function avoid_franklin_parse_errors(out)
     1052         out = replace(out, '`' => "&#96;")
     1052         out = replace(out, '"' => "&#34;")
     1052         out
        -     end
     1082     if !in_place
     1052         out = avoid_franklin_parse_errors(out)
     1052         if !isnothing(out)
     1052             out = ansi2html(out)
        -         end
     1052         err = read(joinpath(repo_path, "stderr.log"), String) 
        -     end
     1082     return (out, err)
        - end
