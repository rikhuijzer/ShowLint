        - function filter_patterns(repo::Repo, patterns::Vector{Pattern})
      153     predicates = repo.tags_predicates
     1506     all_predicates_hold(tags) = all([P(tags) for P in predicates])
      153     filtered_patterns = filter(pat -> all_predicates_hold(pat.tags), patterns)
        - end
