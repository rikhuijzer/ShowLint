        - function repo_page(repo::Repo)
      150     predicates_str = join(repo.tags_predicates, " && ")
      150     headers = []
      150     repo_url = joinpath(repo.host, repo.name)
      150     head = """
        -         ~~~
        -         <h1><a href="$repo_url" target="_blank">$(repo.name)</a></h1>
        -         ~~~
        - 
        -         Showing patterns for which the `tags` satisfy:
        -         *$predicates_str*, and the pattern resulted in at least one match.
        - 
        -         \\toc
        - 
        -         """ 
        - 
      150     function pattern_section(pat)
     1052         diff, err = ShowLint.apply(pat, repo)
     1052         title = pat.title
     1052         id = pat.id
     1052         n_matches = number_of_matches(err)
     1052         n_text = n_matches == 1 ? "hit" : "hits"
     1052         unicode_em_space = " " 
     1052         header = "$title$(unicode_em_space)➤$(unicode_em_space)$n_matches $n_text"
        - 
     1052         if diff == ""
     1013             return ""
        -         else
       39             push!(headers, header)
       39             return """
        -             ### $header
        -             [Pattern #$id](/patterns/#$id)
        - 
        -             $diff
        - 
        -             """
        -         end
        -     end
      150     filtered_patterns = filter_patterns(repo, patterns)
      300     sections = pattern_section.(filtered_patterns)
        - 
      150     return (
        -         headers = headers,
        -         text = join([head, sections...], '\n') 
        -     )
        - end
