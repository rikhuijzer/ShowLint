        - """
        - Remove ANSI color codes from `text`.
        - 
        - $(TYPEDSIGNATURES) 
        - """
        - function ansi2html(text::String)::String
     2104   escape_codes = Dict(
        -     "0;30" => "inherit",
        -     "0;31" => "red",
        -     "0;32" => "green",
        -     "0;34" => "blue",
        -     "0;1" => "inherit",
        -     "0;100;30" => "inherit",
        -     "0;41;30" => "red",
        -     "0;42;30" => "green",
        -     "0;43;30" => "orange",
        -     "0;2" => "gray"
        -   )
     2104   for code in keys(escape_codes)
    10520     before = "[" * code * "m"
    10520     color = escape_codes[code]
    10520     after = "<span style=\"color:$color;\">"
    21040     text = replace(text, before => after)
        -   end
     1052   no_color = "[0m"
     1052   text = replace(text, no_color => "</span>")
     1052   text = replace(text, r"WARNING: [^\n]*$" => "")
     1052   text = replace(text, "/repo/" => "")
     1052   text = replace(text, "" => "") 
     1052   text = replace(text, "<!" => "&#60;!")
     1052   text = replace(text, "[0;7;2m" => "")
     1091   text = text[1:end-6]
     1052   text = strip(text)
     1052   return length(text) < 6 ? 
        -         "" :
        -         """
        -         ~~~ 
        -         <pre>
        -         <div class="hljs">$text</div>
        -         </pre>
        -         ~~~
        -         """
        - end
