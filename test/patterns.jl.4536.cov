        - import JSON
        - 
        - @testset "Patterns" begin
        -     @test SL.patterns_have_valid_indexes()
        - 
        -     function apply(pat::Pattern, code::String; file_extension="jl")
       16         test_dir = joinpath(SL.clones_dir, "test", "test")
        8         rm(test_dir; recursive=true, force=true)
        8         mkpath(test_dir)
        - 
        8         code_file = joinpath(test_dir, "code.$file_extension")
        8         open(code_file, "w") do io
        -             write(io, code)
        -         end
        -         
       16         repo = Repo("test", "test", [SL.default])
        - 
        8         SL.apply(pat, repo; in_place=true)
        - 
        8         read(code_file, String)
        -     end
        - 
        -     P = SL.patterns
        - 
        -     @test apply(P[1], "AbstractArray{Int,1}") == "AbstractVector{Int}"
        -     @test apply(P[2], "if x === missing") == "if ismissing(x)"
        -     @test apply(P[2], "x !== missing") == "!ismissing(x)"
        -     @test apply(P[3], "map(x -> f(x), A)") == "map(f, A)"
        -     @test apply(P[3], "y = x -> f(x)") == "y = f"
        -     @test apply(P[4], "x == true") == "x"
        -     @test apply(P[4], "x == false") == "!x"
        -     @test apply(P[4], "x != false") == "!!x"
        - end
